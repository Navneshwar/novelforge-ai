# ──────────────────────────────────────────────────────
# NovelForge AI - Environment Configuration
# Copy this file to .env and adjust values as needed
# ──────────────────────────────────────────────────────

# Ollama Configuration
# For cloud-routed models use: qwen3.5:cloud, gemma3:27b-cloud, deepseek-v4-flash:cloud
# For local models use: llama3.2:3b, llama3.1:8b, mistral:7b
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
LLM_ENDPOINT=http://localhost:11434/v1

# Embedding Configuration
# Cloud models: qwen3.5:cloud (uses same model for embeddings)
# Local models: all-minilm:latest (384 dims), nomic-embed-text:latest (768 dims)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=384

# Generation Settings
MAX_TOKENS=4096
TEMPERATURE=0.7

# Cognee Configuration
COGNEE_DATABASE_PATH=./data/cognee.db
COGNEE_VECTOR_STORE_PATH=./data/vectors
COGNEE_GRAPH_STORE_PATH=./data/graph

# Database (SQLite default - no setup required)
DATABASE_URL=sqlite:///./data/novelforge.db

# Application
APP_NAME=NovelForge
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-this-to-a-random-string-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=10485760
