# Production config for a public deployment with NO local Ollama dependency.
# Copy this to `.env` on the host (or paste as env vars in your host's dashboard).
#
# Get a free Groq key at https://console.groq.com/keys
# Note: Groq deprecated llama-3.1-8b-instant and llama-3.3-70b-versatile in
# June 2026. openai/gpt-oss-20b is the current fast/cheap replacement — check
# https://console.groq.com/docs/models if this has changed again by the time
# you read this.
LLM_PROVIDER=groq
LLM_MODEL=groq/openai/gpt-oss-20b
LLM_ENDPOINT=
LLM_API_KEY=your-groq-api-key-here

# fastembed runs in-process (ONNX runtime, CPU-only, no server, no API key).
# Same 384 dimensions as the local all-minilm setup, so nothing downstream
# (vector store dims, etc.) needs to change.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_ENDPOINT=
EMBEDDING_DIMENSIONS=384
HUGGINGFACE_TOKENIZER=

# Cognee's own local storage (SQLite relational store, LanceDB vectors,
# NetworkX/Kuzu graph) still writes to disk even with a cloud LLM — only the
# LLM/embedding calls leave the box. Point these at your host's persistent
# volume mount (see DEPLOY.md) so data survives restarts/redeploys.
COGNEE_DATABASE_PATH=./data/cognee.db
COGNEE_VECTOR_STORE_PATH=./data/vectors
COGNEE_GRAPH_STORE_PATH=./data/graph

# App DB — also needs to live on the persistent volume.
DATABASE_URL=sqlite:///./data/novelforge.db

# Single-service deploy (backend serves the built frontend), so this mostly
# doesn't matter — leaving it permissive is fine and one less thing to debug
# under deadline.
CORS_ORIGINS=["*"]

DEBUG=False
SECRET_KEY=change-this-to-a-long-random-string
